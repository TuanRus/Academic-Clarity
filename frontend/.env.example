# Base URL của API. Để mặc định "/api" để dùng Vite dev proxy (xem vite.config.ts).
# Khi build production trỏ thẳng tới backend, ví dụ: https://api.your-domain.com/api
VITE_API_BASE_URL=/api

# (Tùy chọn) Đích proxy khi chạy `npm run dev`. Mặc định http://localhost:5024 (profile "http" của backend).
VITE_API_PROXY_TARGET=http://localhost:5024
